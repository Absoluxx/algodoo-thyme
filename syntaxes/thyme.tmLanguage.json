			"match": "(?i)\\b(pi|e)\\b"
		},
		{
			"name": "support.function.math.thyme",
			"match": "(?i)\\b(sqrt|sin|cos|tan|asin|acos|atan|atan2|min|max|vec.lenSq|vec.len|vec.distSq|vec.dist|sum|log|log10|and|or|boolnegate|comp.eq|comp.g|comp.ge|comp.l|comp.le|comp.ne|add|addlist|divide|mod|multiply|negate|posivate|pow|subtract|toBool|toFloat|toInt|toString|HSL2RGB|HSV2RGB|RGB2HSL|RGB2HSV)(?=\\s*\\()"
