					"name": "support.class.thyme"
				},
				"2": {
					"name": "punctuation.accessor.thyme"
				}
			},
			"end": "(?=[^A-Za-z0-9_])",
			"patterns": [
			{
				"name": "support.variable.property.thyme",
				"match": "(?i)\\b(canPan|panFactor|scrollZoom|scrollZoomFactor|allowDrawSelect|alikeTolerance|dragUndo|dropTexGeomGen|fastSketchToolPreview|selectFactor|sketchMorphDelay|sketchMorphTime|Instaerase|angleColor|tutorialEncircleColor|autoFit|forceFitFactor|velFitFactor|momFitFactor|drawTouches|autoScaleBoxText|blurMaxDraw|blurSpacing|browserThumbnailSize|drawHingesWhenRunning|fixedContextMenu|fontMenuPreview|geomGen_cutoff|geomgen_grow|geomgen_growopaque|geomgen_maxborderallowance|geomgen_minarea|geomgen_mindeltatolerance|geomgen_mintolerance|geomgen_recognizematerial|geomgen_recognizematerial_cutoff|geomgen_recognizematerial_variancefactor|geomgen_removeopaqueholes|geomgen_resolution|geomgen_smartbordercolorchoice|geomgen_tolerance|infoUpdateInterval|prescalebrowserthumbnails|rotatebackground|smoothdist|toolcursoroffset|toolspecificcursors|trapUser|useHSL|arrowkeysmove|ctrlselection|mouseoverhighlight|pressandholdmenus|toolgesturesensitivity|toolgestures)\\b"
			},
			{
			"begin": "(?i)\\b(Forces)(\\.)",
			"beginCaptures": {
				"1": {
					"name": "support.class.thyme"
				},
				"2": {
					"name": "punctuation.accessor.thyme"
				}
			},
			"end": "(?=[^A-Za-z0-9_])",
			"patterns": [
			{
				"name": "support.variable.property.thyme",
				"match": "(?i)\\b(airBuoyancy|airBuoyancyText|airFriction|airFrictionText|angMomScale|angVelScale|anglularMomentum|angularMomentumText|chain|attractionText|attraction|attractionText|chainText|contactCombinationDisstance|drawAngles|drawComponents|drawForces|drawMomentumns|drawNames|drawValues|external|externalText|forceScale|friction|frictionProjection|frictionText|gravity|gravityText|hasAngMomScale|hasAngVelScale|hasForceScale|hasMomScale|hasTorqueScale|hasVelScale|hinge|hingeText|linearMomentumText|maxArrowLength|momScale|normal|normalText|rotation|spring|thruster|springText|thrusterText|torque|torqueScale|torqueText|total|totalText|velScale|velocities)\\b"
			},
			{
				"name": "punctuation.accessor.thyme",
				"match": "\\."
			}]},
			{
				"name": "punctuation.accessor.thyme",
				"match": "\\."
			}]},
			{
				"name": "variable.language.thyme",
				"match": "(?i)\\b(mousePos|fadeColor|fadeRotate|fadeScale|fadeTranslate|maxSPHSpawn|waterColor|waterElongation|waterFanceyFactor|waterMaxElongation|waterReflectiveness|waterRefractiveIndex|waterTracerLightness|waterTracerSize|waterTracers|borderSelectedWidthFactor|borderWidth|chainDensityFactor|lineWidth|maxBorderArea|maxBorderAreaSpecial|maxCogs|laserBroadPhase|laserEvents|laserFuzziness|laserResolution|laserSuperBoost|laserWaterBVH|laserWidth|maxTracerLife|numColorsinRainbow|tracerFuzziness|tracerOverdraw|useLaserFuzzNoShaders|drawBCs|drawBodyCenters|drawCables|drawClipPlanes|drawCollisions|drawMapOBBs|drawOBBs|drawParticleCenters|drawParticleNeighbors|drawScaleIndicator|drawSelectionOBB|drawVertices|enableScriptMenu|fadeAnglePickerTime|polytoolPreviewColor|ScaleGravityField|ShowGravityField|drawVelocityFactor|scalePOWattraction|ScalePOWControllerAcc|ScalePOWHingeImpulseBreakLimit|scalePOWmotorspeed|ScalePOWmotortorque|ScalePOWSpringDamping|ScalePOWStringStrength|POWThrusterForce|alwaysCalcContacts|alwaysCalculateForces|DPI|HQPolygons|autosaveEnable|autosaveTime|changeSimWhenvisualising|checkforupdates|enableUndoMerge|forceVertexPolygonDrawing|groundPlane|hideWelcomeScreen|killerPlanes|language|lastversion|marchingSquaresResolution|maxPlotPoints|maxPointDist|minPointDist|maxUndo|metaCutoff|movetoTrashonOverwrite|pointSize|sceneFadeInTime|screenshotswithalpha|transformAttribs|updateInterval|currentPalette|timeUntilRealTool)\\b"
			},
			{
				"name": "punctuation.accessor.thyme",
				"match": "(?i)\\."
			}
		]
	}]},

					

"event-api": {
	"patterns": [
	{
		"name": "variable.parameter.thyme",
		"match": "(?i)\\b[A-Za-z_][A-Za-z0-9_]*(?=\\.(this|other|clickCount|handled|normal|soundGain|pos|geom|hsv|laser|keyChar|keyCode|pressed|handled|dt)\\b)"
	}]
},



"god-api": {
