"event-special-object-properties": {
	"patterns": [
		{
			"name": "support.variable.property.thyme",
			"match": "(?i)(?<=\\bthis\\.|\\bother\\.)\\b(geom|pos)\\b"
		}
	]
},



"event-object-properties": {
	"patterns": [
