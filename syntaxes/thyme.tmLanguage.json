{
"scopeName": "source.thyme",
"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
"name": "Thyme",
"patterns": [
	{"include": "#comments"},
	{"include": "#numbers"},
	{"include": "#booleans"},
	{"include": "#strings"},
	{"include": "#punctuation"},
	{"include": "#event-special-object-properties"},
	{"include": "#event-properties"},
	{"include": "#event-object-properties"},
	{"include": "#api"},
	{"include": "#variables"},
	{"include": "#functions"},
	{"include": "#user-functions"},
	{"include": "#parameterless-functions"}],
"repository": {



"comments": {
	"patterns": [
	{
		"name": "comment.block.thyme",
		"begin": "/\\*",
		"end": "\\*/"
	},
	{
		"name": "comment.line.double-slash.thyme",
		"match": "(?i)//.*$"
	}]},



"numbers": {
	"patterns": [
	{
		"name": "constant.numeric.float.decimal.thyme",
		"match": "(?i)\\b\\d+\\.\\d+\\b"
	},
	{
		"name": "constant.numeric.float.scientific.thyme",
		"match": "(?i)\\b\\d+(\\.\\d+)?[eE][+-]?\\d+\\b"
	},
	{
		"name": "constant.numeric.float.infinity.thyme",
		"match": "(?i)(\\+|-)?inf|[+-]?∞"
	},
	{
		"name": "constant.numeric.float.nan.thyme",
		"match": "(?i)\\bNaN\\b"
	},
					{
		"name": "constant.numeric.integer.decimal.thyme",
		"match": "(?i)\\b\\d+\\b"
	},
	{
		"name": "constant.numeric.integer.binary.thyme",
		"match": "(?i)\\b0b[01]+\\b"
	},
	{
		"name": "constant.numeric.integer.hex.thyme",
		"match": "(?i)\\b0x[0-9A-Fa-f]+\\b"
	}]},



"booleans": {
	"patterns": [
	{
		"name": "constant.language.boolean.thyme",
		"match": "(?i)\\b(true|false)\\b"
	}]},



"strings": {
	"patterns": [
	{
		"include": "#verbatim-string"
	},
	{
		"include": "#normal-string"
	}]},



"normal-string": {
	"name": "string.quoted.double.thyme",
	"begin": "\"",
	"end": "\"",
	"patterns": [
	{
		"include": "#markup"
	},
	{
		"include": "#escapes"
	}]},



"verbatim-string": {
	"name": "string.quoted.double.verbatim.thyme",
	"begin": "@\"",
	"end": "\"",
	"patterns": [
	{
		"include": "#markup"
	},
	{
		"include": "#verbatim-escapes"
	}]},



"escapes": {
	"patterns": [
	{
		"name": "constant.character.escape.thyme",
		"match": "\\\\(\\\\|\"|n|t)"
	}]},



"verbatim-escapes": {
	"patterns": [
	{
		"name": "constant.character.escape.verbatim.thyme",
		"match": "\"\""
	}]},



"markup": {
	"patterns": [
	{
		"name": "constant.character.escape.entity.thyme",
		"match": "&(amp|apos|gt|lt|quot);"
	},
	{
		"name": "constant.character.escape.entity.numeric.thyme",
		"match": "&#\\d+;"
	},
	{
		"name": "constant.character.escape.entity.numeric.thyme",
		"match": "&#x[0-9A-Fa-f]+;"
	},
	{
		"name": "constant.character.escape.markup.thyme",
		"match": "</?(markup|b|i|u|s|tt|big|small|sup|sub)\\s*>"
	},
	{
		"begin": "<span\\b",
		"beginCaptures": {
			"0": {
				"name": "constant.character.escape.markup.thyme"
			}
		},
		"end": ">",
		"endCaptures": {
			"0": {
				"name": "constant.character.escape.markup.thyme"
			}
		},
		"patterns": [
		{
			"name": "entity.other.attribute-name.thyme",
			"match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*(?=\\=)"
		},
		{
			"name": "keyword.operator.assignment.thyme",
			"match": "="
		},
		{
			"name": "string.quoted.double.attribute-value.thyme",
			"begin": "\"",
			"end": "\""
		}]},
	{
		"name": "constant.character.escape.markup.thyme",
		"match": "</span\\s*>"
	}]},



"punctuation": {
	"patterns": [
	{
		"name": "punctuation.definition.brackets.begin.thyme",
		"match": "\\["
	},
	{
		"name": "punctuation.definition.brackets.end.thyme",
		"match": "\\]"
	},
	{
		"name": "punctuation.definition.parentheses.begin.thyme",
		"match": "\\("
	},
	{
		"name": "punctuation.definition.parentheses.end.thyme",
		"match": "\\)"
	},
	{
		"name": "punctuation.definition.braces.begin.thyme",
		"match": "\\{"
	},
	{
		"name": "punctuation.definition.braces.end.thyme",
		"match": "\\}"
	},
	{
		"name": "punctuation.separator.comma.thyme",
		"match": ","
	}]},



"parameterless-functions": {
	"patterns": [
	{
		"name": "support.function.builtin.thyme",
		"match": "(?i)\\b(groovyOff|exit|quit|groovyOff|groovyOn|time|readable|ResetAll|eval|geval)\\b"
	}]},



"functions": {
	"patterns": [
	{
		"name": "support.function.builtin.thyme",
		"match": "(?i)\\b(print|Bench_Steps|cos|sin|clamp|if|inclusive_range|lerp|ResetTree|for|if|if_then_else)(?=\\s*\\()"
	}]},



"user-functions": {
	"patterns": [
	{
		"name": "support.function.builtin.thyme",
		"match": "(?i)\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*(:?=)\\s*\\(\\s*\\)\\s*=>\\s*\\{)"
	}]},



"api": {
	"patterns": [
	{"include": "#event-api"},
	{"include": "#rand-api"},
	{"include": "#scene-api"},
	{"include": "#math-api"},
	{"include": "#string-api"},
	{"include": "#set-api"},
	{"include": "#keys-api"},
	{"include": "#sph-api"},
	{"include": "#app-api"},
	{"include": "#god-api"}]},



"app-api": {
	"patterns": [
	{
		"begin": "(?i)\\b(app)(\\.)",
		"beginCaptures": {
			"1": {
				"name": "support.class.thyme"
			},
			"2": {
				"name": "punctuation.accessor.thyme"
			}
		},
		"end": "(?i)(?=[^A-Za-z0-9_])",
		"patterns": [
		{
			"name": "support.function.builtin.thyme",
			"match": "(?i)\\b(Step_N)\\b(?=\\s*\\()"
		},
		{
			"name": "support.function.builtin.thyme",
			"match": "(?i)\\b(addUndoPoint|doCheckforupdates|freeupmemory|redo|undo|Step)\\b"
		},
		{
			"begin": "(?i)\\b(Grid)(\\.)",
			"beginCaptures": {
				"1": {
					"name": "support.class.thyme"
				},
				"2": {
					"name": "punctuation.accessor.thyme"
				}
			},
			"end": "(?=[^A-Za-z0-9_])",
			"patterns": [
			{
				"name": "support.variable.property.thyme",
				"match": "(?i)\\b(base|grid|numAxes|opacity|scale|snap|topness)\\b"
			},
			{
				"name": "punctuation.accessor.thyme",
				"match": "\\."
			}]},
